python/
bin/

# Local runtime config; may contain API keys
config.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Virtual environments (if someone uses one manually)
venv/
.venv/

# Node / browser test artifacts
node_modules/
playwright-report/
test-results/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Internal project docs (not for public repo)
.replay/internal/
